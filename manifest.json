{
  "manifest_version": 3,
  "name": "Cyclr",
  "version": "1.1.4",
  "description": "A lightweight, keyboard-driven tab switcher for Chromium browsers, inspired by OS-level Alt-Tab menus.",

  "browser_specific_settings": {
    "gecko": {
      "id": "cyclr@revanthlol.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "favicon"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "icons": {
    "16": "assets/icons/cyclr-16x16.png",
    "32": "assets/icons/cyclr-32x32.png",
    "48": "assets/icons/cyclr-48x48.png",
    "128": "assets/icons/cyclr-128x128.png"
  },

  "action": {
    "default_popup": "src/settings/settings.html",
    "default_icon": {
      "16": "assets/icons/cyclr-16x16.png",
      "32": "assets/icons/cyclr-32x32.png",
      "48": "assets/icons/cyclr-48x48.png",
      "128": "assets/icons/cyclr-128x128.png"
    }
  },

  "background": {
    "service_worker": "src/background/background.js",
    "scripts": ["src/background/background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/content/overlay.js"
      ],
      "css": [
        "src/content/overlay.css"
      ]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "assets/images/*.svg"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "commands": {
    "open-cyclr": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Open Cyclr"
    }
  }
}