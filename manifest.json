{
  "manifest_version": 3,
  "name": "Cyclr Prototype",
  "version": "0.0.1",

  "permissions": [
    "tabs"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "open-cyclr": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Open Cyclr"
    }
  },

  "web_accessible_resources": [
    {
      "resources": [
        "overlay.html",
        "overlay.js",
        "overlay.css"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["overlay.js"],
      "run_at": "document_idle"
    }
  ]
}
